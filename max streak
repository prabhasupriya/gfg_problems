#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
int n;
cin >> n;
while(n-- >0){
    int a;
    cin >> a;
    vector<int> m(a);
    for(int i=0;i<a;i++){
        cin >> m[i];
    }
    int current =0;
    int ma = 0;
    for(int i=0;i<a;i++){
        if(m[i]!=0){
            current +=1;
            ma = max(ma, current);
        }
        else{
            current=0;
        }
    }
    cout << ma <<endl;
}
}
