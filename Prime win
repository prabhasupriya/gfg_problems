include <bits/stdc++.h>
using namespace std;

int main() {
	//your code goes here
int a;
cin>>a;
while(a-- >0){
    int b,c;
    cin >>b>>c;
    int d =b+c;
    bool found=true;
    for(int i=2;i<=sqrt(d);i++){
        if(d%i == 0){
            found = false;
            break;
        }
    }
    if(found){
        cout<<"ALICE"<<endl;
    }
    else{
        cout<<"BOB"<<endl;
    }
}
}
