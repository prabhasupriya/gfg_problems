#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
int n;
cin >> n;
while(n-- >0){
    int m;
    cin >> m;
    string s;
    cin>>s;
    transform(s.begin(),s.end(),s.begin(),::tolower);
    int found =0;
    int count =0;
    for(int i=0;i<m;i++){
        if(s[i]!='a' && s[i]!='e' && s[i]!= 'i' && s[i]!='o' && s[i]!='u'){
            count +=1;
        }
        else{
            count =0;
            
        }
        if(count >=4){
            found =1;
        }
    }
    if(found ==1){
        cout <<"YES"<<endl;
    }
    else {
        cout <<"NO"<<endl;
    }
}
}
