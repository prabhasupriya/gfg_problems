#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
	int n;
	cin >> n;
	while(n-- >0){
	    int a;
	    cin>> a;
	    vector<int> m(a);
	    for(int i=0;i<a;i++){
	        cin >> m[i];
	    }
	    int s = m[0];
	    int ans = 1;
	    for(int i=1;i<a;i++){
	        if(s<m[i]){
	            s=m[i];
	            ans =i+1;
	        }
	    }
	    cout << ans << endl;
	}

}
