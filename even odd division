#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
int n;
cin >>n;
while(n-- >0){
    int a;
    cin >> a;
    int f=0;
    int g=0;
    for(int i=1;i<=a;i++){
        if(a%i ==0){
            if(i%2==0){
                f+=1;
            }
            else{
                g+=1;
            }
        }
    }
    if(f > g){
        cout << "1"<<endl;
    }
    else if(f==g){
        cout <<"0" << endl;
    }
    else {
        cout <<"-1" << endl;
    }
}
}
